# Discord
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID_1=
DISCORD_GUILD_ID_2=
DISCORD_GUILD_1_LABEL=
DISCORD_GUILD_2_LABEL=

# Channels staff (DISCORD_NOTIFICATION_DELAY_MS=0 = pas de délai entre envois)
DISCORD_NOTIFICATION_DELAY_MS=0
STAFF_ALERT_CHANNEL_ID=
STAFF_NEW_TEAM_CHANNEL_ID=
NEW_TEAM_CHANNEL_ID=
STAFF_ARCHIVE_TEAM_CHANNEL_ID=
AUDIT_LOG_CHANNEL_ID=

# Base de données
DATABASE_PATH=./data/tournament.db

# Web admin
WEB_PORT=3000
WEB_HOST=0.0.0.0
WEB_ADMIN_USERNAME=admin
WEB_ADMIN_PASSWORD_HASH=
SESSION_SECRET=
ENABLE_WEB_UI=true

# Google Apps Script
GOOGLE_SCRIPT_URL_1=
GOOGLE_SCRIPT_URL_2=
ENABLE_GOOGLE_SHEETS_SYNC=false

# API métier (aucune valeur hardcodée dans le code)
API_BASE_URL=https://api.leamateur.pro
TOURNAMENT_SLUG=OUATventure Saison 20
TOURNAMENT_ID=18
# Rétrocompatibilité
CALENDAR_TOURNAMENT_ID=18
API_BASE_URL_1=https://api.leamateur.pro
API_BASE_URL_2=https://api.leamateur.pro
API_BASE_URL_3=https://api.leamateur.pro

# Requêtes HTTP
REQUEST_TIMEOUT_MS=15000
REQUEST_RETRY_COUNT=3
REQUEST_RETRY_BASE_DELAY_MS=1000
# User API (rate limit)
USER_API_CACHE_TTL_MS=120000
# TTL cache DB user (ms). 0 = ne réutiliser la DB que si discord_id présent ; >0 = réutiliser si last_fetched_at dans la fenêtre
USER_API_DB_CACHE_TTL_MS=0
USER_API_MAX_CONCURRENT=3
# Throttle appels réels /user/{id} (gros volume / premier run froid)
USER_API_MIN_DELAY_MS=250
USER_API_MAX_CONCURRENCY=1
# Délai min entre deux GET /team/{id} (gros scan, éviter 429)
TEAM_API_MIN_DELAY_MS=150

# Jobs
REGISTRATION_SYNC_INTERVAL_MINUTES=5
# Max notifications "équipe réinscrite" par run ; au-delà = 0 (éviter spam après faux removed)
REACTIVATION_NOTIFY_MAX_PER_RUN=20
ENABLE_AUTOMATIC_REGISTRATION_SYNC=true
SCAN_INTERVAL_MINUTES=5
ENABLE_AUTOMATIC_TEAM_SCAN=true
ENABLE_AUTOMATIC_MEMBER_SYNC=true
ENABLE_AUTOMATIC_PENDING_ACTIONS_RETRY=true

# Environnement
NODE_ENV=development

# Permissions staff (IDs de rôles Discord séparés par des virgules)
ALLOWED_STAFF_ROLE_IDS=

# Rate limit web
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Locks jobs
JOB_LOCK_TTL_SECONDS=300

# Discord limites
CATEGORY_TEAM_BASE_NAME=S21
CATEGORY_MAX_CHANNELS_SAFE_LIMIT=50
DISCORD_ROLE_LIMIT_SAFE_THRESHOLD=240
DISCORD_CHANNEL_LIMIT_SAFE_THRESHOLD=480

# Logs
LOG_LEVEL=info
